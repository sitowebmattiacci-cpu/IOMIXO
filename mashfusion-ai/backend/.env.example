# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/mashfusion

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ── AI Engine ────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=change-me-to-a-random-internal-key

# ── Stripe ───────────────────────────────────────────────
# In TEST mode use sk_test_... and the webhook secret from `stripe listen` (or Test Dashboard endpoint).
# In LIVE mode swap to sk_live_..., the live whsec_... from the Live Dashboard endpoint, and live price IDs.
# Same env var names — different deploy environment loads test vs live values.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...        # Stripe Price ID for Pro    ($29/mo recurring)
STRIPE_STUDIO_PRICE_ID=price_...     # Stripe Price ID for Studio ($79/mo recurring)

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── App URL (used in Stripe redirects) ───────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SMTP (Email) ─────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=IOMIXO <noreply@iomixo.com>

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
