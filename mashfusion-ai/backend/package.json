{
  "name": "iomixo-backend",
  "version": "1.0.0",
  "description": "IOMIXO — Node.js API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests",
