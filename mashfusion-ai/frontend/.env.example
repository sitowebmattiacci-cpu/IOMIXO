# ── API Backend URL ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Stripe (public price IDs) ────────────────────────────
# Use TEST price IDs in dev/staging, LIVE price IDs in production deployments.
# Must match the prices configured on the backend (STRIPE_PRO_PRICE_ID / STRIPE_STUDIO_PRICE_ID).
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...        # Pro    plan ($29/mo)
NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=price_...     # Studio plan ($79/mo)
